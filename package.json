{
  "name": "screwtapp",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "preview:android": "time dotenv -- eas build -p android --local --profile preview --non-interactive --output \"./build/android/screwtapp-preview-$(date +\"%Y_%m_%d_%I_%M_%p\").apk\"",
    "preview:ios": "time dotenv -- eas build -p ios --local --profile preview --non-interactive --output \"./build/ios/screwtapp-preview-$(date +\"%Y_%m_%d_%I_%M_%p\").ipa\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:mutate": "npx stryker run",
    "test:related": "jest --onlyChanged",
    "test:unit": "jest --testPathPattern='features|styles'",
    "test:screens": "jest --testPathPattern='src/app'",
    "ts:check": "tsc",
    "lint": "eslint ."
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@johnhamlin/redux-persist": "^6.1.0",
    "@pchmn/expo-material3-theme": "^1.3.2",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/native": "^7.1.30",
    "@reduxjs/toolkit": "^2.1.0",
    "@sentry/react-native": "^8.1.0",
    "@shopify/flash-list": "2.0.2",
    "@stryker-mutator/api": "^9.5.1",
    "babel-preset-expo": "~54.0.10",
    "dayjs": "^1.11.8",
    "deepmerge": "^4.3.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "normalize-css-color": "^1.0.2",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^4.1.2",
    "react-native-nitro-modules": "^0.33.9",
    "react-native-paper": "^5.12.3",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-text-ticker": "^1.14.0",
    "react-native-track-player": "5.0.0-alpha0",
    "react-native-worklets": "^0.7.4",
    "react-redux": "^9.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/jest-runner": "^9.5.1",
    "@stryker-mutator/typescript-checker": "^9.5.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "chalk": "^5.3.0",
    "eslint": "^8.56.0",
    "eslint-config-universe": "^12.0.0",
    "eslint-plugin-reactotron": "^0.1.2",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "msw": "^2.12.10",
    "prettier": "^3.2.4",
    "reactotron-react-native": "^5.1.18",
    "reactotron-react-native-mmkv": "^0.2.3",
    "reactotron-redux": "^3.2.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "private": true,
  "volta": {
    "node": "22.22.0"
  }
}
